        'type' => 'int',
        'not null' => TRUE,
        'default' => 0,
        'description' => 'Display order within the quiz.',
      ),
      'page_break' => array(
        'type' => 'int',
        'size' => 'tiny',
        'not null' => TRUE,
        'default' => 0,
        'description' => '1 if this section begins a new quiz page.',
      ),
      'validate_on_next' => array(
        'type'     => 'int',
        'size'     => 'tiny',
        'not null' => TRUE,
