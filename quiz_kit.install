        'default' => 0,
        'description' => 'Unix timestamp when the question was last changed.',
      ),
      'answer_layout' => array(
        'type'        => 'varchar',
        'length'      => 16,
        'not null'    => TRUE,
        'default'     => 'horizontal',
        'description' => 'Display layout for answers during quiz-taking: horizontal or vertical.',
      ),
      'scored' => array(
        'type'        => 'int',
        'size'        => 'tiny',
