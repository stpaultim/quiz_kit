/**
 * Implements hook_uninstall().
 */
function quiz_kit_uninstall() {
  // Delete all quiz nodes.
  $nids = db_query("SELECT nid FROM {node} WHERE type = 'quiz_kit_quiz'")->fetchCol();
  if ($nids) {
    node_delete_multiple($nids);
  }

  // Delete field instances and fields.
  $fields = array('field_quiz_category', 'field_quiz_max_attempts', 'field_quiz_pass_rate', 'field_quiz_show_section_scores', 'field_quiz_require_answers', 'field_quiz_time_limit');
  foreach ($fields as $field_name) {
    if ($instance = field_info_instance('node', $field_name, 'quiz_kit_quiz')) {
      field_delete_instance($instance);
    }
    if (field_info_field($field_name)) {
      field_delete_field($field_name);
    }
  }
  field_purge_batch(500);

  // Delete the node type.
  node_type_delete('quiz_kit_quiz');

  // Delete the Quiz Categories vocabulary.
  if (taxonomy_vocabulary_machine_name_load('quiz_kit_categories')) {
    taxonomy_vocabulary_delete('quiz_kit_categories');
  }

  // Remove any stored config/variables.
  db_delete('variable')
    ->condition('name', 'quiz_kit_%', 'LIKE')
    ->execute();
}

