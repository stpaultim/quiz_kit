/**
 * Add the per-quiz time limit field.
 */
function quiz_kit_update_1014() {
  _quiz_kit_create_time_limit_field();
}

/**
 * Creates the field_quiz_time_limit field and instance.
 */
function _quiz_kit_create_time_limit_field() {
  if (!field_info_field('field_quiz_time_limit')) {
    field_create_field(array(
      'field_name'  => 'field_quiz_time_limit',
      'type'        => 'number_integer',
      'cardinality' => 1,
    ));
  }

  if (!field_info_instance('node', 'field_quiz_time_limit', 'quiz_kit_quiz')) {
    field_create_instance(array(
      'field_name'  => 'field_quiz_time_limit',
      'entity_type' => 'node',
      'bundle'      => 'quiz_kit_quiz',
      'label'       => t('Time limit (minutes)'),
      'description' => t('Maximum time allowed to complete the quiz. Leave blank or 0 for no time limit.'),
      'required'    => FALSE,
      'settings'    => array('min' => 0),
      'widget'      => array(
        'type'   => 'number',
        'weight' => 15,
      ),
      'display' => array(
        'default' => array(
          'type'  => 'hidden',
          'label' => 'hidden',
        ),
      ),
    ));
  }
}

/**
 * Add show_in_results column to quiz_kit_question.
 */
function quiz_kit_update_1015() {
  if (!db_field_exists('quiz_kit_question', 'show_in_results')) {
    db_add_field('quiz_kit_question', 'show_in_results', array(
      'type'     => 'int',
      'size'     => 'tiny',
      'not null' => TRUE,
      'default'  => 0,
      'description' => '1 if this question\'s answer should appear as a column in the results list.',
    ));
  }
}
