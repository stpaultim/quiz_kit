/**
 * Implements hook_install().
 */
function quiz_kit_install() {
  // --- Node type ---
  $type = node_type_set_defaults(array(
    'type'        => 'quiz_kit_quiz',
    'name'        => t('Quiz'),
    'base'        => 'node_content',
    'description' => t('A quiz with one or more questions.'),
    'has_title'   => TRUE,
    'title_label' => t('Title'),
    'custom'      => FALSE,
    'modified'    => FALSE,
    'locked'      => TRUE,
    'is_new'      => TRUE,
    'settings'    => array(
      'status_default'  => NODE_NOT_PUBLISHED,
      'promote_enabled' => FALSE,
      'promote_default' => FALSE,
      'sticky_enabled'  => FALSE,
      'sticky_default'  => FALSE,
      'revision_enabled' => FALSE,
      'revision_default' => FALSE,
      'node_preview'    => FALSE,
    ),
  ));
  node_type_save($type);
  node_add_body_field($type, t('Description'));

  // --- Quiz Categories vocabulary ---
  $vocab = new TaxonomyVocabulary(array(
    'name' => t('Quiz Categories'),
    'machine_name' => 'quiz_kit_categories',
    'description' => t('Administrative categories for organising quizzes. Not shown to quiz-takers.'),
  ));
  taxonomy_vocabulary_save($vocab);

  // --- Category field on the quiz node type ---
  if (!field_info_field('field_quiz_category')) {
    field_create_field(array(
      'field_name' => 'field_quiz_category',
      'type' => 'taxonomy_term_reference',
      'cardinality' => 1,
      'settings' => array(
        'allowed_values' => array(
          array(
            'vocabulary' => 'quiz_kit_categories',
            'parent' => 0,
          ),
        ),
      ),
    ));
  }

  field_create_instance(array(
    'field_name' => 'field_quiz_category',
    'entity_type' => 'node',
    'bundle' => 'quiz_kit_quiz',
    'label' => t('Category'),
    'description' => t('Organise this quiz into an administrative category. Not visible to quiz-takers.'),
    'required' => FALSE,
    'widget' => array(
      'type' => 'taxonomy_autocomplete',
      'weight' => 10,
    ),
    'display' => array(
      'default' => array(
        'type' => 'hidden',
        'label' => 'hidden',
      ),
    ),
  ));

  // --- Per-quiz time limit field ---
  _quiz_kit_create_time_limit_field();

  // --- Per-quiz max attempts field ---
  _quiz_kit_create_max_attempts_field();

  // --- Per-quiz pass rate field ---
  _quiz_kit_create_pass_rate_field();

  // --- Per-quiz show section scores field ---
  _quiz_kit_create_show_section_scores_field();

  // --- Per-quiz require answers field ---
  _quiz_kit_create_require_answers_field();
}

/**
 * Creates the field_quiz_max_attempts field and instance.
 */
function _quiz_kit_create_max_attempts_field() {
  if (!field_info_field('field_quiz_max_attempts')) {
    field_create_field(array(
      'field_name'  => 'field_quiz_max_attempts',
      'type'        => 'number_integer',
      'cardinality' => 1,
    ));
  }

  if (!field_info_instance('node', 'field_quiz_max_attempts', 'quiz_kit_quiz')) {
    field_create_instance(array(
      'field_name'  => 'field_quiz_max_attempts',
      'entity_type' => 'node',
      'bundle'      => 'quiz_kit_quiz',
      'label'       => t('Maximum attempts'),
      'description' => t('How many times a user may take this quiz. Leave blank to use the site-wide default (0 = unlimited).'),
      'required'    => FALSE,
      'settings'    => array('min' => 0),
      'widget'      => array(
        'type'   => 'number',
        'weight' => 14,
      ),
      'display' => array(
        'default' => array(
          'type'  => 'hidden',
          'label' => 'hidden',
        ),
      ),
    ));
  }
}

