/**
 * Introduce quiz_kit_quiz_question junction table; remove nid/section_id/weight
 * from quiz_kit_question.
 */
function quiz_kit_update_1008() {
  // 1. Create the junction table if it doesn't already exist.
  if (!db_table_exists('quiz_kit_quiz_question')) {
    db_create_table('quiz_kit_quiz_question', array(
      'description' => 'Junction table: maps questions to quizzes with per-quiz ordering and section assignment.',
      'fields' => array(
        'id' => array(
          'type' => 'serial',
          'unsigned' => TRUE,
          'not null' => TRUE,
          'description' => 'Primary key.',
        ),
        'nid' => array(
          'type' => 'int',
          'unsigned' => TRUE,
          'not null' => TRUE,
          'description' => 'The {node}.nid of the quiz.',
        ),
        'question_id' => array(
          'type' => 'int',
          'unsigned' => TRUE,
          'not null' => TRUE,
          'description' => 'The {quiz_kit_question}.id.',
        ),
        'section_id' => array(
          'type' => 'int',
          'unsigned' => TRUE,
          'not null' => TRUE,
          'default' => 0,
          'description' => 'The {quiz_kit_section}.id. 0 = no section.',
        ),
        'weight' => array(
          'type' => 'int',
          'not null' => TRUE,
          'default' => 0,
          'description' => 'Display order within this quiz.',
        ),
      ),
      'primary key' => array('id'),
      'indexes' => array(
        'nid' => array('nid'),
        'question_id' => array('question_id'),
      ),
    ));
  }

  // 2. Migrate existing question rows into the junction table.
  db_query('INSERT INTO {quiz_kit_quiz_question} (nid, question_id, section_id, weight)
            SELECT nid, id, section_id, weight FROM {quiz_kit_question}');

  // 3. Drop index and columns from quiz_kit_question.
  if (db_index_exists('quiz_kit_question', 'nid')) {
    db_drop_index('quiz_kit_question', 'nid');
  }
  if (db_field_exists('quiz_kit_question', 'nid')) {
    db_drop_field('quiz_kit_question', 'nid');
  }
  if (db_field_exists('quiz_kit_question', 'section_id')) {
    db_drop_field('quiz_kit_question', 'section_id');
  }
  if (db_field_exists('quiz_kit_question', 'weight')) {
    db_drop_field('quiz_kit_question', 'weight');
  }
}

/**
 * Fix the show_section_scores field widget to use options_onoff (checkbox).
 */
function quiz_kit_update_1007() {
  $instance = field_info_instance('node', 'field_quiz_show_section_scores', 'quiz_kit_quiz');
  if ($instance) {
    $instance['widget'] = array(
      'type'     => 'options_onoff',
      'weight'   => 12,
      'settings' => array('display_label' => 1),
    );
    field_update_instance($instance);
  }
}

/**
 * Ensure all section-related schema changes are applied.
 *
 * Acts as a catch-all in case updates 1002–1005 were skipped due to a
 * schema-version mismatch during development. All operations are guarded
 * by existence checks so running this more than once is safe.
 */
function quiz_kit_update_1006() {
  // quiz_kit_section table.
  if (!db_table_exists('quiz_kit_section')) {
    db_create_table('quiz_kit_section', array(
      'description' => 'Stores sections that group questions within a quiz.',
      'fields' => array(
        'id' => array(
          'type' => 'serial', 'unsigned' => TRUE, 'not null' => TRUE,
          'description' => 'Primary key.',
        ),
        'nid' => array(
          'type' => 'int', 'unsigned' => TRUE, 'not null' => TRUE,
          'description' => 'The {node}.nid of the quiz.',
        ),
        'title' => array(
          'type' => 'varchar', 'length' => 255, 'not null' => TRUE, 'default' => '',
          'description' => 'Section title.',
        ),
        'instructions' => array(
          'type' => 'text', 'size' => 'medium', 'not null' => FALSE,
          'description' => 'Optional instructions shown at the top of this section.',
        ),
        'weight' => array(
          'type' => 'int', 'not null' => TRUE, 'default' => 0,
          'description' => 'Display order within the quiz.',
        ),
        'page_break' => array(
          'type' => 'int', 'size' => 'tiny', 'not null' => TRUE, 'default' => 0,
          'description' => '1 if this section begins a new quiz page.',
        ),
      ),
      'primary key' => array('id'),
      'indexes' => array('nid' => array('nid')),
    ));
  }

  // section_id column on quiz_kit_question.
  if (!db_field_exists('quiz_kit_question', 'section_id')) {
    db_add_field('quiz_kit_question', 'section_id', array(
      'type'        => 'int',
      'unsigned'    => TRUE,
      'not null'    => TRUE,
      'default'     => 0,
      'description' => 'The {quiz_kit_section}.id. 0 = no section.',
    ));
  }

  // quiz_kit_result_section table.
  if (!db_table_exists('quiz_kit_result_section')) {
    db_create_table('quiz_kit_result_section', array(
      'description' => 'Stores per-section scores within a quiz result.',
      'fields' => array(
        'id' => array(
          'type' => 'serial', 'unsigned' => TRUE, 'not null' => TRUE,
          'description' => 'Primary key.',
        ),
        'result_id' => array(
          'type' => 'int', 'unsigned' => TRUE, 'not null' => TRUE,
          'description' => 'The {quiz_kit_result}.id.',
        ),
        'section_id' => array(
          'type' => 'int', 'unsigned' => TRUE, 'not null' => TRUE,
          'description' => 'The {quiz_kit_section}.id.',
        ),
        'score' => array(
          'type' => 'float', 'not null' => TRUE, 'default' => 0,
          'description' => 'Section score as a percentage (0–100).',
        ),
      ),
      'primary key' => array('id'),
      'indexes' => array('result_id' => array('result_id')),
    ));
  }

  // field_quiz_show_section_scores node field.
  _quiz_kit_create_show_section_scores_field();
}

