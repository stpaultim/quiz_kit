      'type'        => 'list_boolean',
      'cardinality' => 1,
      'settings'    => array(
        'allowed_values' => array(0 => '', 1 => ''),
      ),
    ));
  }

  if (!field_info_instance('node', 'field_quiz_show_section_scores', 'quiz_kit_quiz')) {
    field_create_instance(array(
      'field_name'  => 'field_quiz_show_section_scores',
      'entity_type' => 'node',
      'bundle'      => 'quiz_kit_quiz',
      'label'       => t('Show section scores'),
      'description' => t('When enabled, quiz-takers see a score breakdown by section on the results page.'),
      'required'    => FALSE,
      'widget' => array(
        'type'     => 'options_onoff',
        'weight'   => 12,
        'settings' => array('display_label' => 1),
      ),
      'display' => array(
        'default' => array(
          'type'  => 'hidden',
          'label' => 'hidden',
        ),
