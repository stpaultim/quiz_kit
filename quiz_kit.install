/**
 * Creates the field_quiz_require_answers field and instance.
 */
function _quiz_kit_create_require_answers_field() {
  if (!field_info_field('field_quiz_require_answers')) {
    field_create_field(array(
      'field_name'  => 'field_quiz_require_answers',
      'type'        => 'list_boolean',
      'cardinality' => 1,
      'settings'    => array(
        'allowed_values' => array(0 => '', 1 => ''),
      ),
    ));
  }

  if (!field_info_instance('node', 'field_quiz_require_answers', 'quiz_kit_quiz')) {
    field_create_instance(array(
      'field_name'  => 'field_quiz_require_answers',
      'entity_type' => 'node',
      'bundle'      => 'quiz_kit_quiz',
      'label'       => t('Require all answers'),
      'description' => t('When enabled, quiz-takers must answer every question before proceeding.'),
      'required'    => FALSE,
      'widget' => array(
        'type'     => 'options_onoff',
        'weight'   => 13,
        'settings' => array('display_label' => 1),
