/**
 * Add the per-quiz pass rate field to existing installations.
 */
function quiz_kit_update_1001() {
  _quiz_kit_create_pass_rate_field();
}

/**
 * Add the quiz sections table.
 */
function quiz_kit_update_1002() {
  if (!db_table_exists('quiz_kit_section')) {
    db_create_table('quiz_kit_section', array(
      'description' => 'Stores sections that group questions within a quiz.',
      'fields' => array(
        'id' => array(
          'type' => 'serial',
          'unsigned' => TRUE,
          'not null' => TRUE,
          'description' => 'Primary key.',
        ),
        'nid' => array(
          'type' => 'int',
          'unsigned' => TRUE,
          'not null' => TRUE,
          'description' => 'The {node}.nid of the quiz.',
        ),
        'title' => array(
          'type' => 'varchar',
          'length' => 255,
          'not null' => TRUE,
          'default' => '',
          'description' => 'Section title.',
        ),
        'instructions' => array(
          'type' => 'text',
          'size' => 'medium',
          'not null' => FALSE,
          'description' => 'Optional instructions shown at the top of this section.',
        ),
        'weight' => array(
          'type' => 'int',
          'not null' => TRUE,
          'default' => 0,
          'description' => 'Display order within the quiz.',
        ),
        'page_break' => array(
          'type' => 'int',
          'size' => 'tiny',
          'not null' => TRUE,
          'default' => 0,
          'description' => '1 if this section begins a new quiz page.',
        ),
      ),
      'primary key' => array('id'),
      'indexes' => array('nid' => array('nid')),
    ));
  }
}

/**
 * Add section_id column to quiz_kit_question.
 */
function quiz_kit_update_1003() {
  if (!db_field_exists('quiz_kit_question', 'section_id')) {
    db_add_field('quiz_kit_question', 'section_id', array(
      'type'        => 'int',
      'unsigned'    => TRUE,
      'not null'    => TRUE,
      'default'     => 0,
      'description' => 'The {quiz_kit_section}.id. 0 = no section.',
    ));
  }
}

/**
